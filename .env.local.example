# Resend API key — sign up at https://resend.com and create a key.
RESEND_API_KEY=

# The address bookings are sent FROM. Must be on a domain you've verified in Resend.
BOOKING_FROM_EMAIL=booking@edmondsbarbershop.com

# Owner addresses notified of every new booking. OWNER_EMAIL_1 is required
# and receives the email as the primary recipient; OWNER_EMAIL_2 and
# OWNER_EMAIL_3 are optional and, if set, are Cc'd.
OWNER_EMAIL_1=
OWNER_EMAIL_2=
OWNER_EMAIL_3=
